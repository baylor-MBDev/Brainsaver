{
  "expo": {
    "name": "DOOMTYPE",
    "slug": "doomtype",
    "version": "1.2.2",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#EFEBFF",
    "splash": {
      "backgroundColor": "#221C3A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.mockingbird.doomtype"
    },
    "android": {
      "package": "dev.mockingbird.doomtype",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EFEBFF"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
